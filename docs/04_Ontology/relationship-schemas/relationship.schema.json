{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FisioOS Relationship",
  "type": "object",
  "required": [
    "subject",
    "predicate",
    "object"
  ],
  "properties": {
    "subject": {
      "type": "string"
    },
    "predicate": {
      "type": "string"
    },
    "object": {
      "type": "string"
    },
    "source": {},
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "enum": [
        "Candidate",
        "Review",
        "Approved",
        "Deprecated"
      ]
    }
  },
  "additionalProperties": false
}
